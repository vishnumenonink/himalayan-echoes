---
/**
 * Bhutan — closing CTA.
 * Brand-green panel with editorial copy + CTA into journeys.
 */
---

<section id="bhutan-cta" class="relative overflow-hidden" style="background: var(--color-brand-green);">

  <img
    src="/icon.png"
    alt=""
    aria-hidden="true"
    class="absolute top-1/2 right-8 lg:right-16 -translate-y-1/2 w-[160px] lg:w-[220px] select-none pointer-events-none hidden md:block"
    style="filter: brightness(0) invert(1); opacity: 0.10;"
  />

  <div class="container-edge mx-auto py-16 lg:py-20 relative">
    <div class="max-w-2xl">
      <p class="text-eyebrow text-cream/80 mb-3 reveal-fast">Begin Here</p>

      <h2 class="font-display text-h2 leading-[1.05] text-cream mb-5 reveal">
        Experience Bhutan with us.
      </h2>

      <p class="text-base lg:text-lg text-cream/85 leading-relaxed mb-8 max-w-xl reveal">
        Let us craft your perfect journey through the hidden kingdom.
      </p>

      <a
        href="/journeys"
        class="group inline-flex items-center gap-3 bg-cream text-ink rounded-full pl-6 pr-2.5 py-2.5 hover:bg-brand-orange hover:text-cream transition-colors duration-500"
      >
        <span class="text-sm tracking-wider">Discover Journeys</span>
        <span class="w-9 h-9 rounded-full bg-ink/10 group-hover:bg-cream/15 flex items-center justify-center transition-colors duration-500">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-500 group-hover:translate-x-1">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>
