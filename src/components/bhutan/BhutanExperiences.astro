---
/**
 * Bhutan — "What awaits you" experience grid.
 * Six experience cards in a 3+3 grid (matches Why Himalayan Echoes pattern).
 * Drop client copy into the experiences array when ready.
 */

interface Experience {
  title: string;
  description: string;
  iconPath: string;
}

const experiences: Experience[] = [
  { title: "[Experience one]",   description: "[Short description to be supplied.]", iconPath: "M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" },
  { title: "[Experience two]",   description: "[Short description to be supplied.]", iconPath: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" },
  { title: "[Experience three]", description: "[Short description to be supplied.]", iconPath: "M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.8 2c1.2 1.5 4.2 6.5 4.2 11.5a8.5 8.5 0 0 1-8.5 8.5z M2 21c0-3 1.85-5.36 5.08-6 1.5-.3 5.42-.5 7.42-3" },
  { title: "[Experience four]",  description: "[Short description to be supplied.]", iconPath: "M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" },
  { title: "[Experience five]",  description: "[Short description to be supplied.]", iconPath: "M12 2l4.5 4.5L22 12l-4.5 4.5L12 22l-4.5-4.5L2 12l4.5-4.5L12 2z M10 12l1.5 1.5L15 10" },
  { title: "[Experience six]",   description: "[Short description to be supplied.]", iconPath: "M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" },
];
---

<section id="experiences" class="bg-cream relative pt-24 lg:pt-28 pb-24 lg:pb-28">
  <img
    src="/icon.png"
    alt=""
    aria-hidden="true"
    class="absolute top-12 -left-10 lg:-left-4 w-[160px] lg:w-[200px] select-none pointer-events-none"
    style="filter: brightness(0); opacity: 0.04; transform: rotate(-8deg);"
  />

  <div class="container-edge mx-auto relative">

    {/* Header */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mb-20 lg:mb-24 items-end">
      <div class="lg:col-span-7">
        <p class="text-eyebrow text-brand-orange mb-5 reveal-fast">What awaits you</p>
        <h2 class="font-display text-h1 leading-[1.0] text-ink reveal">
          [Section headline — to be supplied]
        </h2>
      </div>
      <p class="lg:col-span-5 text-ink-soft text-base lg:text-lg leading-relaxed reveal">
        [Section intro — to be supplied. A few lines about what travellers
        encounter when they choose Bhutan.]
      </p>
    </div>

    {/* Experience grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-14 lg:gap-y-16 gap-x-10 lg:gap-x-16">
      {experiences.map((e) => (
        <article class="bx-tile group relative">
          <span class="bx-icon absolute -top-2 lg:-top-3 right-0 pointer-events-none transition-all duration-700"
                style="color: var(--color-brand-orange); opacity: 0.18;">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-16 h-16 lg:w-20 lg:h-20"
              set:html={`<path d="${e.iconPath}" />`}
            />
          </span>

          <div class="bx-line h-px bg-ink/20 mb-6 transition-colors duration-500"></div>

          <div class="relative z-10 pr-24">
            <h3 class="font-display text-h3 leading-[1.1] text-ink mb-3 transition-transform duration-500 group-hover:translate-x-1">
              {e.title}
            </h3>
            <p class="text-ink-soft text-base leading-relaxed max-w-sm">
              {e.description}
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .bx-tile:hover .bx-line {
    background: var(--color-brand-orange);
    height: 2px;
  }
  .bx-tile:hover .bx-icon {
    opacity: 0.85 !important;
    transform: scale(1.05);
  }
  .bx-tile {
    transition: transform 0.5s var(--ease-out-expo, cubic-bezier(0.19, 1, 0.22, 1));
  }
</style>
