---
/**
 * Bhutan — collage-esque horizontal gallery.
 * Hand-picked 14 images (mixed portrait + landscape) for visual rhythm.
 * Horizontal scroll on desktop with snap; click any image → Swiper lightbox.
 */

interface Item {
  src: string;
  orient: "p" | "l";
}

const items: Item[] = [
  { src: "/images/gallery/g-1.jpg",  orient: "p" },
  { src: "/images/gallery/g-2.jpg",  orient: "l" },
  { src: "/images/gallery/g-4.jpg",  orient: "p" },
  { src: "/images/gallery/g-7.jpg",  orient: "l" },
  { src: "/images/gallery/g-21.jpg", orient: "p" },
  { src: "/images/gallery/g-11.jpg", orient: "l" },
  { src: "/images/gallery/g-5.jpg",  orient: "p" },
  { src: "/images/gallery/g-12.jpg", orient: "l" },
  { src: "/images/gallery/g-6.jpg",  orient: "p" },
  { src: "/images/gallery/g-13.jpg", orient: "l" },
  { src: "/images/gallery/g-8.jpg",  orient: "p" },
  { src: "/images/gallery/g-14.jpg", orient: "l" },
  { src: "/images/gallery/g-9.jpg",  orient: "p" },
  { src: "/images/gallery/g-15.jpg", orient: "l" },
  { src: "/images/gallery/g-10.jpg", orient: "p" },
];
---

<section id="bhutan-gallery" class="bg-cream relative py-20 lg:py-24 overflow-hidden">

  {/* Header */}
  <div class="container-edge mx-auto mb-12 lg:mb-14">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="text-eyebrow text-brand-orange mb-5 reveal-fast">A Glimpse</p>
        <h2 class="font-display text-h1 leading-[1.02] text-ink max-w-xl reveal">
          Bhutan in frames.
        </h2>
      </div>
      <p class="text-ink-soft text-sm md:text-base max-w-sm flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
        Scroll horizontally — click any image to expand.
      </p>
    </div>
  </div>

  {/* Horizontal scroll track */}
  <div class="gallery-track-wrap relative">
    <div class="gallery-track flex gap-4 lg:gap-5 overflow-x-auto snap-x snap-mandatory pb-4">
      {/* Left padding spacer — matches container-edge */}
      <div class="shrink-0" style="width: clamp(1.25rem, 4vw, 3rem);"></div>

      {items.map((it, i) => (
        <button
          type="button"
          class="gallery-item shrink-0 snap-start overflow-hidden rounded-2xl bg-paper relative group cursor-zoom-in"
          data-index={i}
          style={`height: clamp(360px, 56vh, 560px); aspect-ratio: ${it.orient === "p" ? "2/3" : "3/2"};`}
        >
          <img src={it.src} alt={`Bhutan gallery ${i + 1}`} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
          {/* hover hint */}
          <span class="absolute top-4 right-4 w-10 h-10 rounded-full bg-cream/90 text-ink flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 3 21 3 21 9" />
              <polyline points="9 21 3 21 3 15" />
              <line x1="21" y1="3" x2="14" y2="10" />
              <line x1="3" y1="21" x2="10" y2="14" />
            </svg>
          </span>
        </button>
      ))}

      {/* Right padding spacer */}
      <div class="shrink-0" style="width: clamp(1.25rem, 4vw, 3rem);"></div>
    </div>
  </div>

  {/* Lightbox */}
  <div id="gallery-lightbox" class="fixed inset-0 z-[200] bg-charcoal/95 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-500 flex items-center justify-center">

    {/* Close */}
    <button id="gallery-close" class="absolute top-6 right-6 lg:top-10 lg:right-10 w-12 h-12 rounded-full border border-cream/50 text-cream flex items-center justify-center hover:bg-cream hover:text-charcoal transition-colors duration-300 z-30" aria-label="Close gallery">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>

    {/* Swiper */}
    <div class="lightbox-swiper w-full max-w-6xl px-16 md:px-20">
      <div class="swiper-wrapper">
        {items.map((it, i) => (
          <div class="swiper-slide flex items-center justify-center">
            <div class="relative max-h-[85vh] max-w-full flex items-center justify-center">
              <img src={it.src} alt={`Bhutan ${i + 1}`} class="max-h-[85vh] max-w-full object-contain rounded-sm shadow-[0_40px_120px_-30px_rgba(0,0,0,0.8)]" />
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* Lightbox arrows */}
    <button id="lb-prev" class="absolute left-4 lg:left-10 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full border border-cream/50 text-cream flex items-center justify-center hover:bg-cream hover:text-charcoal transition-colors duration-300 z-30" aria-label="Previous image">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12" />
        <polyline points="12 19 5 12 12 5" />
      </svg>
    </button>
    <button id="lb-next" class="absolute right-4 lg:right-10 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full border border-cream/50 text-cream flex items-center justify-center hover:bg-cream hover:text-charcoal transition-colors duration-300 z-30" aria-label="Next image">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </button>

    {/* Counter */}
    <div class="absolute bottom-6 lg:bottom-10 left-1/2 -translate-x-1/2 text-cream/85 text-sm tracking-widest font-mono z-30">
      <span class="lb-current">01</span>
      <span class="opacity-50 mx-1">/</span>
      <span class="lb-total">15</span>
    </div>
  </div>
</section>

<style>
  /* Hide scrollbar but keep functional */
  .gallery-track::-webkit-scrollbar {
    height: 6px;
  }
  .gallery-track::-webkit-scrollbar-track {
    background: transparent;
  }
  .gallery-track::-webkit-scrollbar-thumb {
    background: rgba(19, 27, 112, 0.15);
    border-radius: 3px;
  }
  .gallery-track::-webkit-scrollbar-thumb:hover {
    background: rgba(19, 27, 112, 0.3);
  }

  /* Smooth scroll feel */
  .gallery-track {
    scroll-behavior: smooth;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Keyboard } from "swiper/modules";
  import "swiper/css";

  // --- Build lightbox swiper ---
  const swiper = new Swiper(".lightbox-swiper", {
    modules: [Navigation, Keyboard],
    slidesPerView: 1,
    spaceBetween: 32,
    speed: 500,
    loop: true,
    navigation: { prevEl: "#lb-prev", nextEl: "#lb-next" },
    keyboard: { enabled: true },
    on: {
      slideChange(s) {
        const cur = document.querySelector(".lb-current");
        if (cur) cur.textContent = String(s.realIndex + 1).padStart(2, "0");
      },
    },
  });

  // --- Open / close lightbox ---
  const lightbox = document.getElementById("gallery-lightbox");
  const closeBtn = document.getElementById("gallery-close");
  const items = document.querySelectorAll<HTMLButtonElement>(".gallery-item");

  function open(index: number) {
    if (!lightbox) return;
    swiper.slideToLoop(index, 0);
    lightbox.style.opacity = "1";
    lightbox.style.pointerEvents = "auto";
    document.documentElement.style.overflow = "hidden";
  }
  function close() {
    if (!lightbox) return;
    lightbox.style.opacity = "0";
    lightbox.style.pointerEvents = "none";
    document.documentElement.style.overflow = "";
  }

  items.forEach((btn) => {
    btn.addEventListener("click", () => {
      const i = Number(btn.dataset.index || 0);
      open(i);
    });
  });
  closeBtn?.addEventListener("click", close);
  lightbox?.addEventListener("click", (e) => { if (e.target === lightbox) close(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });

  // --- Drag-to-scroll on the horizontal track (desktop) ---
  const track = document.querySelector<HTMLElement>(".gallery-track");
  if (track) {
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;

    track.addEventListener("mousedown", (e) => {
      isDown = true;
      track.classList.add("cursor-grabbing");
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    track.addEventListener("mouseleave", () => {
      isDown = false;
      track.classList.remove("cursor-grabbing");
    });
    track.addEventListener("mouseup", () => {
      isDown = false;
      track.classList.remove("cursor-grabbing");
    });
    track.addEventListener("mousemove", (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });
  }
</script>
