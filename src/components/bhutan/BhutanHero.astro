---
/**
 * Bhutan — half-page hero.
 */
---

<section class="relative w-full h-[60vh] lg:h-[65vh] overflow-hidden bg-charcoal">
  <img
    src="/images/bhutan-hero-main.jpg"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-charcoal/30 via-charcoal/35 to-charcoal/55 pointer-events-none"></div>

  <div class="relative h-full flex items-center justify-center text-center text-cream container-edge mx-auto pt-20">
    <div class="max-w-4xl">
      <p class="text-eyebrow text-brand-orange mb-5 reveal-fast">Discover Bhutan</p>
      <h1 class="font-display text-display lg:text-hero leading-[0.98] reveal">
        The hidden kingdom.
      </h1>
      <p class="text-base lg:text-lg text-cream/85 mt-6 max-w-2xl mx-auto leading-relaxed reveal">
        One of the world's last untouched countries.
      </p>
    </div>
  </div>
</section>
