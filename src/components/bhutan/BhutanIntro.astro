---
/**
 * Bhutan — centered editorial intro.
 * Mirrors the Journeys intro pattern. Drop in the client copy when ready.
 */
---

<section id="bhutan-intro" class="bg-cream relative">
  <div class="container-edge mx-auto py-20 lg:py-28">
    <div class="max-w-3xl mx-auto text-center">

      <p class="text-base text-brand-orange leading-relaxed mb-10 reveal">
        [Eyebrow tagline — to be supplied by client]
      </p>

      <div class="space-y-6 text-ink-soft text-base leading-relaxed">
        <p class="reveal">
          [Opening paragraph about Bhutan — the kingdom, its character,
          why it draws travellers seeking something more than sightseeing.
          To be supplied.]
        </p>

        <p class="reveal">
          [Second paragraph — the depth of culture, the rhythm of life,
          what makes Bhutan distinct from anywhere else. To be supplied.]
        </p>

        <p class="reveal">
          [Third paragraph — closing reflection. What a traveller takes home.
          To be supplied.]
        </p>
      </div>

      <div class="mt-12 reveal-fast">
        <a
          href="#experiences"
          class="group inline-flex items-center gap-4 bg-brand-orange text-cream rounded-full pl-7 pr-3 py-2.5 hover:bg-brand-blue transition-colors duration-500"
        >
          <span class="text-sm tracking-wider">Explore Bhutan</span>
          <span class="w-10 h-10 rounded-full bg-cream/15 flex items-center justify-center transition-transform duration-500 group-hover:translate-y-0.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19" />
              <polyline points="19 12 12 19 5 12" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
