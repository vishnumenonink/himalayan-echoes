---
/**
 * Bhutan — short teaser section linking to the full Journeys page.
 * Image + headline + paragraph + CTA. Drop client copy in when ready.
 */
---

<section id="bhutan-journeys" class="relative w-full bg-cream py-20 lg:py-24 overflow-hidden">
  <div class="container-edge mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      {/* Image */}
      <div class="lg:col-span-7 order-2 lg:order-1">
        <div class="relative w-full aspect-[3/2] overflow-hidden rounded-sm shadow-[0_30px_60px_-30px_rgba(19,27,112,0.4)] img-zoom">
          <img
            src="/images/journeys/landscape-2.jpg"
            alt=""
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      {/* Copy */}
      <div class="lg:col-span-5 order-1 lg:order-2">
        <p class="text-eyebrow text-brand-orange mb-5 reveal-fast">Crafted Journeys</p>
        <h2 class="font-display text-h1 leading-[1.02] text-ink mb-6 reveal">
          [Teaser headline — to be supplied]
        </h2>
        <p class="text-ink-soft text-base lg:text-lg leading-relaxed mb-10 reveal">
          [A short paragraph inviting the reader to explore the full Bhutan
          journey collection. To be supplied.]
        </p>

        <a
          href="/journeys"
          class="group inline-flex items-center gap-4 bg-brand-orange text-cream rounded-full pl-7 pr-3 py-2.5 hover:bg-brand-blue transition-colors duration-500 reveal-fast"
        >
          <span class="text-sm tracking-wider">View all Bhutan journeys</span>
          <span class="w-10 h-10 rounded-full bg-cream/15 flex items-center justify-center transition-transform duration-500 group-hover:translate-x-1">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </span>
        </a>
      </div>

    </div>
  </div>
</section>
