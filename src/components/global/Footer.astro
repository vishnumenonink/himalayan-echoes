---
const year = new Date().getFullYear();
---

<footer class="bg-snow text-ink relative">
  <div class="container-edge mx-auto pt-20 lg:pt-24 pb-10">

    {/* Top — brand + columns */}
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16 pb-16 border-b border-ink/15">

      {/* Brand */}
      <div class="md:col-span-5">
        <img
          src="/logo/logo.png"
          alt="Himalayan Echoes"
          class="h-20 lg:h-24 w-auto mb-6"
        />
        <p class="text-ink-soft max-w-sm leading-relaxed text-sm">
          Bespoke, deeply considered journeys through Bhutan, Nepal, Tibet, and
          the wider Himalayan world. Crafted in Thimphu, shared with the world.
        </p>
      </div>

      {/* Explore */}
      <div class="md:col-span-2">
        <p class="text-eyebrow text-brand-orange mb-5">Explore</p>
        <ul class="space-y-3 text-sm text-ink">
          <li><a href="/journeys" class="hover:text-brand-orange transition-colors">Journeys</a></li>
          <li><a href="/#destinations" class="hover:text-brand-orange transition-colors">Destinations</a></li>
          <li><a href="/#story" class="hover:text-brand-orange transition-colors">Our Story</a></li>
          <li><a href="/#journal" class="hover:text-brand-orange transition-colors">Journal</a></li>
        </ul>
      </div>

      {/* About */}
      <div class="md:col-span-2">
        <p class="text-eyebrow text-brand-orange mb-5">About</p>
        <ul class="space-y-3 text-sm text-ink">
          <li><a href="/#why" class="hover:text-brand-orange transition-colors">Why Himalayan Echoes</a></li>
          <li><a href="/#commitment" class="hover:text-brand-orange transition-colors">Our Commitment</a></li>
          <li><a href="/#testimonials" class="hover:text-brand-orange transition-colors">Guest Stories</a></li>
          <li><a href="#contact" class="hover:text-brand-orange transition-colors">Contact</a></li>
        </ul>
      </div>

      {/* Contact + Newsletter */}
      <div class="md:col-span-3">
        <p class="text-eyebrow text-brand-orange mb-5">Get in touch</p>
        <ul class="space-y-3 text-sm text-ink mb-8">
          <li>
            <a href="mailto:hello@himalayanechoes.travel" class="hover:text-brand-orange transition-colors">
              hello@himalayanechoes.travel
            </a>
          </li>
          <li class="text-ink-soft">Thimphu, Bhutan</li>
        </ul>

        <p class="text-eyebrow text-brand-orange mb-4">Whispers from the mountains</p>
        <form class="flex border-b border-ink/30 pb-2">
          <input
            type="email"
            placeholder="Your email"
            class="bg-transparent flex-1 outline-none placeholder:text-ink/40 text-sm text-ink py-1"
          />
          <button class="text-sm text-ink hover:text-brand-orange transition" aria-label="Subscribe">
            →
          </button>
        </form>
      </div>
    </div>

    {/* Bottom — legal + socials */}
    <div class="mt-10 flex flex-col md:flex-row md:justify-between gap-6 text-xs text-ink-soft">
      <div class="flex flex-col md:flex-row gap-3 md:gap-8">
        <p>© {year} Himalayan Echoes. All rights reserved.</p>
        <div class="flex gap-6">
          <a href="#" class="hover:text-brand-orange transition-colors">Privacy</a>
          <a href="#" class="hover:text-brand-orange transition-colors">Terms</a>
          <a href="#" class="hover:text-brand-orange transition-colors">Cookies</a>
        </div>
      </div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-brand-orange transition-colors" aria-label="Instagram">Instagram</a>
        <a href="#" class="hover:text-brand-orange transition-colors" aria-label="Facebook">Facebook</a>
        <a href="#" class="hover:text-brand-orange transition-colors" aria-label="LinkedIn">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
