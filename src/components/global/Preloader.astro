---
/**
 * Two-stage Preloader — Himalayan Echoes
 *
 * Stage 1 (Entry):
 *   · Full-bleed image with "Begin the journey" CTA
 *   · User click guarantees audio gesture
 *
 * Stage 2 (Cinematic, ~4.3s):
 *   · Background image takes a small black tint (slight darken)
 *   · Himalayan Echoes logo emerges smoothly, holds, dissolves
 *   · Whole preloader fades out to reveal the site
 *   · Audio continues briefly into the hero, then fades gently
 *
 * Session-gated — won't re-show on internal navigation.
 */
---

<div id="preloader" class="fixed inset-0 z-[100] bg-charcoal overflow-hidden">
  {/* Image layer */}
  <img
    src="/images/preloader.jpg"
    alt=""
    class="preloader-image absolute inset-0 w-full h-full object-cover"
    fetchpriority="high"
    decoding="sync"
  />

  {/* Static vignette (always present) */}
  <div
    class="preloader-vignette absolute inset-0 pointer-events-none"
    style="background:
      radial-gradient(ellipse at center, rgba(0,0,0,0) 0%, rgba(0,0,0,0.35) 70%, rgba(0,0,0,0.6) 100%),
      linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, transparent 30%, transparent 70%, rgba(0,0,0,0.3) 100%);"
  ></div>

  {/* STAGE 1 — Entry */}
  <div id="preloader-entry" class="absolute inset-0 z-[10] flex flex-col items-center justify-center text-cream px-6">
    <p class="entry-eyebrow text-eyebrow text-cream/70 mb-6">Himalayan Echoes</p>

    <h2 class="entry-title font-display text-display leading-[0.95] text-center max-w-3xl mb-12">
      A journey<br/>begins quietly.
    </h2>

    <button
      id="preloader-enter"
      class="group inline-flex items-center gap-4 border border-cream/60 rounded-full pl-7 pr-3 py-2.5 hover:bg-cream hover:text-charcoal transition-colors duration-500 entry-cta"
      aria-label="Begin the journey"
    >
      <span class="text-sm tracking-wider">Begin the journey</span>
      <span class="w-10 h-10 rounded-full bg-cream/15 group-hover:bg-charcoal/15 flex items-center justify-center transition-colors duration-500">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </span>
    </button>

    <p class="entry-sound text-eyebrow text-cream/50 mt-12 flex items-center gap-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
      </svg>
      Best experienced with sound
    </p>
  </div>

  {/* STAGE 2 — Cinematic */}
  <div id="preloader-cinematic" class="absolute inset-0 z-[20] hidden">
    {/* Dark tint overlay — fades in once entry is dismissed */}
    <div class="preloader-darken absolute inset-0 bg-charcoal"></div>

    {/* Centered logo */}
    <div class="absolute inset-0 flex items-center justify-center">
      <img
        src="/logo/logo.png"
        alt="Himalayan Echoes"
        class="preloader-logo w-auto h-36 md:h-52 drop-shadow-[0_2px_24px_rgba(0,0,0,0.45)]"
      />
    </div>
  </div>

  {/* Audio */}
  <audio id="preloader-audio" preload="auto" loop>
    <source src="/audio/background-score.mp3" type="audio/mpeg" />
  </audio>
</div>

<style>
  /* Initial states */
  .preloader-image   { opacity: 0; transform: scale(1.04); }
  .preloader-logo    { opacity: 0; transform: translateY(20px) scale(0.98); }
  .preloader-darken  { opacity: 0; }

  /* Entry stage initial states */
  .entry-eyebrow,
  .entry-title,
  .entry-cta,
  .entry-sound { opacity: 0; transform: translateY(16px); }
</style>

<script>
  import { gsap } from "gsap";

  const CINEMATIC_DURATION = 4.3; // total seconds after Begin click
  const SESSION_KEY = "he-preloader-shown";

  const preloader = document.getElementById("preloader");
  const entry = document.getElementById("preloader-entry");
  const cinematic = document.getElementById("preloader-cinematic");
  const enterBtn = document.getElementById("preloader-enter");
  const image = document.querySelector<HTMLImageElement>(".preloader-image");
  const darken = document.querySelector<HTMLElement>(".preloader-darken");
  const logo = document.querySelector<HTMLImageElement>(".preloader-logo");
  const audio = document.getElementById("preloader-audio") as HTMLAudioElement | null;

  if (sessionStorage.getItem(SESSION_KEY) === "1") {
    preloader?.remove();
  } else if (preloader && entry && cinematic && enterBtn) {
    sessionStorage.setItem(SESSION_KEY, "1");
    document.documentElement.style.overflow = "hidden";

    // ---------- Stage 1: Entry intro ----------
    const entryTl = gsap.timeline();
    entryTl
      .to(image, { opacity: 1, scale: 1.0, duration: 1.4, ease: "power2.out" }, 0)
      .to(".entry-eyebrow", { opacity: 1, y: 0, duration: 1.0, ease: "expo.out" }, 0.4)
      .to(".entry-title",   { opacity: 1, y: 0, duration: 1.2, ease: "expo.out" }, 0.6)
      .to(".entry-cta",     { opacity: 1, y: 0, duration: 1.0, ease: "expo.out" }, 0.9)
      .to(".entry-sound",   { opacity: 1, y: 0, duration: 0.9, ease: "expo.out" }, 1.1);

    // ---------- Stage 2: triggered on Enter click ----------
    enterBtn.addEventListener("click", () => {
      // Start audio (guaranteed — user gesture)
      if (audio) {
        audio.volume = 0.7;
        audio.play().catch(() => {});
      }

      // Reveal cinematic layer (still hidden behind entry visually until entry fades)
      cinematic.classList.remove("hidden");

      // Fade entry layer out concurrent with cinematic start
      gsap.to(entry, {
        opacity: 0,
        duration: 0.5,
        ease: "power2.out",
        onComplete: () => { entry.style.display = "none"; },
      });

      runCinematic();
    });

    function runCinematic() {
      const tl = gsap.timeline({
        onComplete: () => {
          // Audio: linger a beat after preloader gone, then gently fade
          if (audio) {
            gsap.to(audio, {
              volume: 0,
              duration: 2.0,
              delay: 0.4,
              ease: "sine.inOut",
              onComplete: () => audio.pause(),
            });
          }
        },
      });

      // 0.0s — small dark tint settles over the image (subtle, not opaque)
      tl.to(darken, { opacity: 0.35, duration: 0.9, ease: "power2.out" }, 0);

      // Continuous gentle Ken Burns throughout
      tl.to(image, { scale: 1.08, duration: CINEMATIC_DURATION, ease: "power1.out" }, 0);

      // 0.5s — Logo emerges smoothly
      tl.to(logo, { opacity: 1, y: 0, scale: 1, duration: 1.4, ease: "expo.out" }, 0.5);

      // Hold logo briefly (logo visible from ~1.9s to ~3.0s)
      // 3.0s — Logo dissolves
      tl.to(logo, { opacity: 0, y: -6, duration: 0.7, ease: "power2.in" }, 3.0);

      // 3.4s — Preloader fades out, page revealed
      tl.to(preloader, {
        opacity: 0,
        duration: 0.9,
        ease: "power2.inOut",
        onComplete: () => {
          preloader.remove();
          document.documentElement.style.overflow = "";
        },
      }, 3.4);
    }
  }
</script>
