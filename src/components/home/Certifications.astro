---
/**
 * Certifications — infinite ticker / marquee of accreditation logos.
 * 6 logos. Shows ~5 at a time, continuously scrolling left.
 * Duplicated set keeps the loop seamless.
 */

const logos = [1, 2, 3, 4, 5, 6].map((n) => ({
  src: `/images/certifications/${n}.png`,
  alt: `Certification ${n}`,
}));
---

<section id="certifications" class="bg-cream relative pt-16 pb-20 lg:pb-24 overflow-hidden">
  <div class="container-edge mx-auto">
    <p class="text-eyebrow text-brand-orange text-center mb-10 reveal-fast">
      Certified & Accredited By
    </p>
  </div>

  {/* Marquee track */}
  <div class="cert-marquee relative">
    {/* Edge fades for the polished entry/exit */}
    <div class="absolute left-0 top-0 bottom-0 w-24 lg:w-40 bg-gradient-to-r from-cream to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 lg:w-40 bg-gradient-to-l from-cream to-transparent z-10 pointer-events-none"></div>

    <div class="cert-track flex items-center gap-16 lg:gap-24">
      {/* Set A */}
      {logos.map((l) => (
        <div class="cert-cell flex items-center justify-center shrink-0 w-32 lg:w-40 h-20 lg:h-24">
          <img
            src={l.src}
            alt={l.alt}
            class="max-w-full max-h-full object-contain"
            loading="lazy"
          />
        </div>
      ))}
      {/* Set B — exact duplicate so the loop seams cleanly */}
      {logos.map((l) => (
        <div class="cert-cell flex items-center justify-center shrink-0 w-32 lg:w-40 h-20 lg:h-24" aria-hidden="true">
          <img
            src={l.src}
            alt=""
            class="max-w-full max-h-full object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Seamless infinite marquee.
     Track holds 2 copies of the logo set. We translate by -50% to loop perfectly. */
  .cert-track {
    animation: certScroll 30s linear infinite;
    width: max-content;
  }
  @keyframes certScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  /* Pause on hover for legibility */
  .cert-marquee:hover .cert-track {
    animation-play-state: paused;
  }
</style>
