---
/**
 * Editorial Hero Slider — Himalayan Echoes
 * Three slides:
 *   1. Slider-1 image (Welcome / Journeys that transform)
 *   2. Slider-2 image (Transformation / Where time stands still)
 *   3. Vimeo background video (same copy as slide 1)
 */

type SlideKind = "image" | "video";
interface Slide {
  kind: SlideKind;
  src?: string;
  youtubeId?: string;
  startAt?: number;
  eyebrow: string;
  title: string;
  lede: string;
}

const slides: Slide[] = [
  {
    kind: "image",
    src: "/images/slider-1.png",
    eyebrow: "Welcome to Himalayan Echoes",
    title: "Journeys that transform",
    lede: "Curated luxury journeys across Bhutan, Ladakh, Nepal and the remote Himalayas.",
  },
  {
    kind: "image",
    src: "/images/slider-2.png",
    eyebrow: "Transformation",
    title: "Where time<br/>stands still",
    lede: "Trek pristine trails and explore untouched Himalayan wilderness.",
  },
  {
    kind: "video",
    youtubeId: "I732jx1fzv4",
    startAt: 0,
    eyebrow: "Welcome to Himalayan Echoes",
    title: "Journeys that transform",
    lede: "Curated luxury journeys across Bhutan, Ladakh, Nepal and the remote Himalayas.",
  },
];
---

<section class="relative w-full h-screen overflow-hidden bg-charcoal" id="hero">
  <!-- Swiper container -->
  <div class="hero-swiper">
    <div class="swiper-wrapper">
      {slides.map((slide) => (
        <div class="swiper-slide">
          {/* Media layer */}
          <div class="absolute inset-0">
            {slide.kind === "image" && (
              <img
                src={slide.src}
                alt={slide.title}
                class="kb-image w-full h-full object-cover"
                loading="eager"
                decoding="async"
              />
            )}
            {slide.kind === "video" && slide.youtubeId && (
              <div class="absolute inset-0 w-full h-full overflow-hidden">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${slide.youtubeId}?autoplay=1&mute=1&loop=1&playlist=${slide.youtubeId}&controls=0&showinfo=0&rel=0&modestbranding=1&start=${slide.startAt ?? 0}&playsinline=1&iv_load_policy=3&fs=0&disablekb=1`}
                  class="absolute top-1/2 left-1/2 pointer-events-none yt-bg"
                  data-yt-id={slide.youtubeId}
                  data-yt-start={slide.startAt ?? 0}
                  frameborder="0"
                  allow="autoplay; encrypted-media; picture-in-picture"
                  title="Himalayan Echoes — cinematic"
                ></iframe>
              </div>
            )}
            {/* Cinematic gradient overlays */}
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-charcoal/80"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-charcoal/55 via-charcoal/15 to-transparent"></div>
          </div>

          {/* Copy layer */}
          <div class="relative z-10 h-full flex items-end pb-24 md:pb-32">
            <div class="container-edge mx-auto w-full">
              <div class="max-w-4xl text-cream">
                <p class="text-eyebrow text-cream/85 mb-6 slide-eyebrow">
                  {slide.eyebrow}
                </p>
                <h1 class="text-hero font-display leading-[0.95] slide-title" set:html={slide.title}></h1>
                <p class="text-lede mt-8 max-w-2xl text-cream/85 slide-lede">
                  {slide.lede}
                </p>

                <div class="mt-12 flex flex-wrap items-center gap-5 slide-cta">
                  <a
                    href="/journeys"
                    class="inline-flex items-center gap-3 bg-brand-orange text-cream rounded-full px-7 py-4 text-sm hover:bg-brand-yellow hover:text-charcoal transition-colors duration-500"
                  >
                    Explore journeys
                    <span aria-hidden="true">→</span>
                  </a>
                  <a
                    href="#story"
                    class="inline-flex items-center gap-3 border border-cream/60 text-cream rounded-full px-7 py-4 text-sm hover:bg-cream hover:text-charcoal transition-colors duration-500"
                  >
                    Our story
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  {/* Slide counter + arrow controls (bottom right) */}
  <div class="absolute bottom-8 right-6 md:bottom-12 md:right-12 z-30 flex items-center gap-5">
    <div class="text-cream/80 text-sm font-mono tracking-wider tabular-nums">
      <span class="hero-current">01</span>
      <span class="opacity-50 mx-1">/</span>
      <span class="hero-total">03</span>
    </div>
    <div class="flex gap-3">
      <button
        class="hero-prev w-12 h-12 rounded-full border border-cream/50 text-cream flex items-center justify-center hover:bg-cream hover:text-charcoal transition-colors duration-300"
        aria-label="Previous slide"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
      </button>
      <button
        class="hero-next w-12 h-12 rounded-full border border-cream/50 text-cream flex items-center justify-center hover:bg-cream hover:text-charcoal transition-colors duration-300"
        aria-label="Next slide"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </button>
    </div>
  </div>

  {/* Scroll cue */}
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-cream/70 z-20 hidden md:flex flex-col items-center gap-3">
    <span class="text-eyebrow">Scroll</span>
    <span class="block w-px h-10 bg-cream/40 relative overflow-hidden">
      <span class="absolute top-0 left-0 right-0 h-1/3 bg-cream animate-scrollCue"></span>
    </span>
  </div>
</section>

<style>
  @keyframes scrollCue {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(300%); }
  }
  .animate-scrollCue {
    animation: scrollCue 2.4s var(--ease-in-out-quart) infinite;
  }

  /* YouTube background-video true cover (16:9 preserved, fills viewport, scaled to crop YouTube's bars) */
  .yt-bg {
    width: max(100vw, 177.78vh);
    height: max(100vh, 56.25vw);
    /* Scale 1.35× so YouTube's letterbox / chrome bars are cropped off-screen */
    transform: translate(-50%, -50%) scale(1.35);
  }
</style>

<script>
  import Swiper from "swiper";
  import { EffectFade, Navigation } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/effect-fade";
  import { gsap } from "gsap";

  const swiper = new Swiper(".hero-swiper", {
    modules: [EffectFade, Navigation],
    effect: "fade",
    fadeEffect: { crossFade: true },
    speed: 1200,
    loop: true,
    navigation: {
      prevEl: ".hero-prev",
      nextEl: ".hero-next",
    },
    on: {
      init(s) {
        animateSlideIn(s.slides[s.activeIndex]);
        updateCounter(s.realIndex, s.slides.length);
      },
      slideChangeTransitionStart(s) {
        animateSlideIn(s.slides[s.activeIndex]);
        updateCounter(s.realIndex, s.slides.length);
      },
    },
  });

  function updateCounter(realIndex: number, total: number) {
    const current = document.querySelector(".hero-current");
    const totalEl = document.querySelector(".hero-total");
    if (current) current.textContent = String(realIndex + 1).padStart(2, "0");
    if (totalEl) {
      // Swiper loop mode duplicates slides; subtract 2 for the duplicates
      const actual = total - 2 > 0 ? total - 2 : total;
      totalEl.textContent = String(actual).padStart(2, "0");
    }
  }

  function animateSlideIn(slideEl: HTMLElement) {
    const eyebrow = slideEl.querySelector(".slide-eyebrow");
    const title = slideEl.querySelector(".slide-title");
    const lede = slideEl.querySelector(".slide-lede");
    const cta = slideEl.querySelector(".slide-cta");

    gsap.set([eyebrow, title, lede, cta], { opacity: 0, y: 30 });
    gsap.to(eyebrow, { opacity: 1, y: 0, duration: 0.9, ease: "expo.out", delay: 0.2 });
    gsap.to(title,   { opacity: 1, y: 0, duration: 1.2, ease: "expo.out", delay: 0.35 });
    gsap.to(lede,    { opacity: 1, y: 0, duration: 1.0, ease: "expo.out", delay: 0.55 });
    gsap.to(cta,     { opacity: 1, y: 0, duration: 0.9, ease: "expo.out", delay: 0.75 });
  }
</script>
