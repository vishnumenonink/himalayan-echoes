---
/**
 * Story / Philosophy Section — Vertical sticky-stack cards.
 *
 * Left: Philosophy text + Plan a journey CTA (sticky as user scrolls).
 * Right: Three landscape cards stacked vertically with a small gap.
 *        Each card is `position: sticky` at the same top offset →
 *        as the user scrolls, each new card slides up to sit on top
 *        of the previous one (deck-of-cards effect).
 *
 * No GSAP pin / no fixed huge scroll distance — flows naturally.
 */

const destinations = [
  { name: "Bhutan",  region: "Eastern Himalayas",  image: "/images/hero-1.jpg",
    caption: "Where every valley holds a story carved by faith and time." },
  { name: "Ladakh",  region: "Trans-Himalayas",    image: "/images/hero-2.jpg",
    caption: "Vast silences and skies so close you could touch them." },
  { name: "Nepal",   region: "Central Himalayas",  image: "/images/hero-3.jpg",
    caption: "Where the spirit of the mountains lives in every footstep." },
];
---

<section id="story" class="bg-cream relative pt-14 lg:pt-16 pb-24 lg:pb-32">
  <div class="container-edge mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      {/* ============ LEFT — Philosophy (sticky so it stays in view) ============ */}
      <div class="lg:col-span-5 lg:sticky lg:top-28 lg:self-start">
        <p class="text-eyebrow text-brand-orange mb-6 reveal-fast">
          Our Philosophy
        </p>

        <h2 class="font-display text-h1 leading-[1.02] text-ink mb-8 reveal">
          Where journeys awaken<br class="hidden md:inline" />
          stories within.
        </h2>

        <div class="space-y-5 text-ink-soft text-base lg:text-lg leading-relaxed max-w-xl">
          <p class="reveal">
            In the Himalayas, stories are not simply told — they are lived. They
            echo through mountain villages, sacred monasteries, ancient traditions
            and quiet landscapes shaped by time.
          </p>
          <p class="reveal">
            At Himalayan Echoes, we create immersive luxury journeys that invite
            travellers to connect more deeply with the people, culture and spirit
            of the region.
          </p>
          <p class="reveal">
            Every journey is personal. Designed with care and intention, each
            experience reveals hidden places, meaningful encounters and moments
            that stay with you long after you return home.
          </p>
        </div>

        <div class="mt-10 reveal">
          <a
            href="#enquire"
            class="group inline-flex items-center gap-4 bg-brand-orange text-cream rounded-full pl-7 pr-3 py-2.5 hover:bg-brand-blue transition-colors duration-500"
          >
            <span class="text-sm tracking-wider">Plan your journey</span>
            <span class="w-10 h-10 rounded-full bg-cream/15 flex items-center justify-center transition-transform duration-500 group-hover:translate-x-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </span>
          </a>
        </div>
      </div>

      {/* ============ RIGHT — Sticky stacking cards ============ */}
      <div class="lg:col-span-7">
        <div class="space-y-4">
          {destinations.map((d, i) => (
            <article
              class="story-card group relative w-full aspect-[16/10] overflow-hidden rounded-3xl shadow-[0_30px_60px_-30px_rgba(19,27,112,0.45)]"
              style={`z-index: ${i + 1};`}
            >
              <img
                src={d.image}
                alt={d.name}
                class="w-full h-full object-cover"
                loading={i === 0 ? "eager" : "lazy"}
              />

              {/* Default state: destination name only, white, bottom-left */}
              <div class="story-card-default absolute inset-0 p-6 lg:p-8 flex items-end transition-opacity duration-500">
                <h3 class="font-display text-display text-cream leading-none drop-shadow-[0_2px_18px_rgba(0,0,0,0.45)]">
                  {d.name}
                </h3>
              </div>

              {/* Hover state: blue tint + full details */}
              <div class="story-card-hover absolute inset-0 opacity-0 transition-opacity duration-500 pointer-events-none">
                <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/35 to-ink/10"></div>

                {/* Bottom-left: region + name + caption */}
                <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8 text-cream flex items-end justify-between gap-6">
                  <div class="flex-1 min-w-0">
                    <p class="text-eyebrow text-cream/80 mb-2">{d.region}</p>
                    <h3 class="font-display text-h2 leading-none mb-3">{d.name}</h3>
                    <p class="text-sm lg:text-base text-cream/90 max-w-md leading-relaxed">
                      {d.caption}
                    </p>
                  </div>

                  {/* Bottom-right: Learn more */}
                  <span class="inline-flex items-center gap-2 text-eyebrow text-cream border-b border-cream/60 pb-1 shrink-0">
                    Learn more
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Each card sticks at the same offset from the viewport top.
     Because they share the same top value, later cards in the DOM
     stack on top of earlier ones as the user scrolls → deck effect. */
  @media (min-width: 1024px) {
    .story-card {
      position: sticky;
      top: 120px;
    }
  }

  /* Hover swap — default fades out, hover fades in */
  .story-card:hover .story-card-default {
    opacity: 0;
  }
  .story-card:hover .story-card-hover {
    opacity: 1;
  }
</style>
