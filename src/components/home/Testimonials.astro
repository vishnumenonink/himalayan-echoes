---
/**
 * Testimonials — Three-up editorial carousel.
 *
 * Six testimonials. Three visible at a time on desktop, two on tablet, one on mobile.
 * Click the orange arrow buttons (top-right) to advance by ONE slide at a time.
 * Loops infinitely.
 */

interface Testimonial {
  quote: string;
  name: string;
  location: string;
}

const testimonials: Testimonial[] = [
  { quote: "More than memories — I came home changed.",                                   name: "Priya R.",     location: "Singapore" },
  { quote: "We didn't just arrive in Bhutan, we felt truly welcomed into it.",            name: "Genevieve H.", location: "Canada" },
  { quote: "They connected us to the living culture of Bhutan in the most personal way.", name: "Sejal P.",     location: "United States" },
  { quote: "This wasn't just a trip; it was a reset.",                                    name: "Sarah W.",     location: "United Kingdom" },
  { quote: "This journey left footprints on my heart.",                                   name: "Daniel M.",    location: "Australia" },
  { quote: "Bhutan pulled at my heartstrings — every detail was unforgettable.",          name: "Cameron C.",   location: "Sweden" },
];
---

<section id="testimonials" class="bg-cream relative pt-6 lg:pt-8 pb-24">
  <div class="container-edge mx-auto">

    {/* Header row */}
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12">
      <div>
        <p class="text-eyebrow text-brand-orange mb-5 reveal-fast">Guests Speak</p>
        <h2 class="font-display text-h1 leading-[1.02] text-ink max-w-2xl reveal">
          Stories that linger.
        </h2>
      </div>

      {/* Right side: orange arrow buttons + counter */}
      <div class="flex flex-col items-start md:items-end gap-4">
        <div class="flex items-center gap-3">
          <button
            class="t-prev w-12 h-12 rounded-full bg-brand-orange text-cream flex items-center justify-center hover:bg-brand-blue transition-colors duration-300"
            aria-label="Previous testimonials"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12" />
              <polyline points="12 19 5 12 12 5" />
            </svg>
          </button>
          <button
            class="t-next w-12 h-12 rounded-full bg-brand-orange text-cream flex items-center justify-center hover:bg-brand-blue transition-colors duration-300"
            aria-label="Next testimonials"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        </div>
        <div class="text-sm tracking-widest font-mono text-ink-mute">
          <span class="t-current">01</span>
          <span class="opacity-50 mx-1">/</span>
          <span>0{testimonials.length}</span>
        </div>
      </div>
    </div>

    {/* Swiper carousel — 3 visible, advances by 1 */}
    <div class="testimonials-swiper !overflow-hidden">
      <div class="swiper-wrapper items-stretch">
        {testimonials.map((t) => (
          <div class="swiper-slide h-auto">
            <article class="t-card h-full bg-paper border border-line rounded-sm p-8 lg:p-10 flex flex-col">
              <span class="block font-display text-brand-orange text-5xl leading-none mb-6 select-none">"</span>
              <p class="font-display text-lg lg:text-xl xl:text-2xl leading-[1.3] text-ink mb-8 flex-1">
                {t.quote}
              </p>
              <div class="pt-5 border-t border-ink/15">
                <p class="text-sm font-medium text-ink">{t.name}</p>
                <p class="text-eyebrow text-ink-mute mt-1">{t.location}</p>
              </div>
            </article>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation } from "swiper/modules";
  import "swiper/css";

  const swiper = new Swiper(".testimonials-swiper", {
    modules: [Navigation],
    slidesPerView: 1,
    spaceBetween: 20,
    speed: 650,
    loop: true,
    loopAdditionalSlides: 2,
    breakpoints: {
      640:  { slidesPerView: 1.2, spaceBetween: 24 },
      768:  { slidesPerView: 2,   spaceBetween: 28 },
      1024: { slidesPerView: 3,   spaceBetween: 32 },
    },
    navigation: { prevEl: ".t-prev", nextEl: ".t-next" },
    on: {
      init(s) { updateCounter(s.realIndex); },
      slideChange(s) { updateCounter(s.realIndex); },
    },
  });

  function updateCounter(realIndex: number) {
    const el = document.querySelector(".t-current");
    if (el) el.textContent = String(realIndex + 1).padStart(2, "0");
  }
</script>

<style>
  .t-card {
    background: var(--color-paper);
  }
</style>
