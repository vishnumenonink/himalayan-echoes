---
/**
 * TripAdvisor mini CTA — quiet trust signal.
 * Logo + stars + copy stack tightly in the middle; wide whitespace either side.
 */
---

<section id="tripadvisor" class="bg-paper relative py-16 lg:py-20 border-t border-b border-line">
  <div class="container-edge mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-center gap-8 lg:gap-12 max-w-4xl mx-auto text-center md:text-left">

      {/* Logo */}
      <div class="shrink-0">
        <img
          src="/images/trip-advisor.webp"
          alt="TripAdvisor"
          class="h-14 lg:h-16 w-auto object-contain"
          loading="lazy"
        />
      </div>

      {/* Content block */}
      <div class="max-w-xl">
        {/* 5 gold stars */}
        <div class="flex items-center justify-center md:justify-start gap-1 mb-4">
          {[1, 2, 3, 4, 5].map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5A615" stroke="#F5A615" stroke-width="1" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
          ))}
        </div>

        <p class="text-ink-soft text-base lg:text-lg leading-relaxed mb-4">
          Rated excellent by our guests on TripAdvisor. Real reviews from travellers
          who've experienced our journeys.
        </p>

        <a
          href="https://www.tripadvisor.com"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 text-sm tracking-wider text-ink border-b border-ink/40 pb-1 hover:text-brand-orange hover:border-brand-orange transition-colors duration-300"
        >
          Read our reviews on TripAdvisor
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-500 group-hover:translate-x-1">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
