---
/**
 * Why Himalayan Echoes — Editorial principles wall.
 *
 * Six tiles arranged in a 3+3 grid. Each tile has a massive faded brand-orange
 * numeral as the visual anchor (sits behind/beside the title), with the title
 * and description layered over a hairline divider.
 * On hover: numeral lights up, hairline shifts to brand-orange, content lifts.
 */

interface USP {
  title: string;
  description: string;
  iconPath: string;   // SVG path-d for the icon
}

/* Stroke-based icons (Feather-style) — paired thoughtfully with each USP */
const usps: USP[] = [
  {
    title: "Deep local knowledge",
    description: "Based in Thimphu with trusted access across the Himalayas.",
    iconPath: "M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z",
  },
  {
    title: "Rare access",
    description: "Private encounters beyond the guidebooks.",
    iconPath: "M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4",
  },
  {
    title: "Luxury expertise",
    description: "Thoughtful service and personal journeys.",
    iconPath: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
  },
  {
    title: "Responsible travel",
    description: "Supporting communities and conservation.",
    iconPath: "M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.8 2c1.2 1.5 4.2 6.5 4.2 11.5a8.5 8.5 0 0 1-8.5 8.5z M2 21c0-3 1.85-5.36 5.08-6 1.5-.3 5.42-.5 7.42-3",
  },
  {
    title: "Effortless planning",
    description: "Every detail handled behind the scenes.",
    iconPath: "M12 2l4.5 4.5L22 12l-4.5 4.5L12 22l-4.5-4.5L2 12l4.5-4.5L12 2z M10 12l1.5 1.5L15 10",
  },
  {
    title: "Hidden experiences",
    description: "Untold stories and quieter corners.",
    iconPath: "M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z",
  },
];
---

<section id="why" class="bg-cream relative pt-24 lg:pt-28 pb-24 lg:pb-28">

  {/* Subtle decorative brand icon top-left (very faint, editorial accent) */}
  <img
    src="/icon.png"
    alt=""
    aria-hidden="true"
    class="absolute top-12 -left-10 lg:-left-4 w-[160px] lg:w-[200px] select-none pointer-events-none"
    style="filter: brightness(0); opacity: 0.04; transform: rotate(-8deg);"
  />

  <div class="container-edge mx-auto relative">

    {/* Header — split: left has eyebrow + title, right has intro */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mb-20 lg:mb-24 items-end">
      <div class="lg:col-span-7">
        <p class="text-eyebrow text-brand-orange mb-5 reveal-fast">Why Himalayan Echoes</p>
        <h2 class="font-display text-h1 leading-[1.0] text-ink reveal">
          Trusted by discerning<br class="hidden md:inline" />
          travellers.
        </h2>
      </div>
      <p class="lg:col-span-5 text-ink-soft text-base lg:text-lg leading-relaxed reveal">
        Immersive luxury journeys crafted with care, executed with expertise,
        and remembered forever.
      </p>
    </div>

    {/* USP grid — 3 cols × 2 rows */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-14 lg:gap-y-16 gap-x-10 lg:gap-x-16">
      {usps.map((u) => (
        <article class="why-tile group relative">
          {/* Icon — top-right anchor */}
          <span class="why-icon absolute -top-2 lg:-top-3 right-0 pointer-events-none transition-all duration-700"
                style="color: var(--color-brand-orange); opacity: 0.18;">
            <svg
              width="72"
              height="72"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-16 h-16 lg:w-20 lg:h-20"
              set:html={`<path d="${u.iconPath}" />`}
            />
          </span>

          {/* Top hairline */}
          <div class="why-line h-px bg-ink/20 mb-6 transition-colors duration-500"></div>

          {/* Title + description */}
          <div class="relative z-10 pr-24">
            <h3 class="font-display text-h3 leading-[1.1] text-ink mb-3 transition-transform duration-500 group-hover:translate-x-1">
              {u.title}
            </h3>
            <p class="text-ink-soft text-base leading-relaxed max-w-sm">
              {u.description}
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  /* Hover: hairline becomes brand-orange, icon brightens */
  .why-tile:hover .why-line {
    background: var(--color-brand-orange);
    height: 2px;
  }
  .why-tile:hover .why-icon {
    opacity: 0.85 !important;
    transform: scale(1.05);
  }
  .why-tile {
    transition: transform 0.5s var(--ease-out-expo, cubic-bezier(0.19, 1, 0.22, 1));
  }
</style>
