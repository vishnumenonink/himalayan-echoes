---
import Base from "../layouts/Base.astro";
import BhutanHero from "../components/bhutan/BhutanHero.astro";
import BhutanIntro from "../components/bhutan/BhutanIntro.astro";
import BhutanExperiences from "../components/bhutan/BhutanExperiences.astro";
import BhutanGallery from "../components/bhutan/BhutanGallery.astro";
import BhutanJourneysTeaser from "../components/bhutan/BhutanJourneysTeaser.astro";
import FinalCta from "../components/home/FinalCta.astro";
---

<Base
  title="Bhutan — Himalayan Echoes"
  description="Discover Bhutan with Himalayan Echoes — bespoke journeys through the kingdom of happiness."
  transparentHeader={true}
>
  <BhutanHero />
  <BhutanIntro />
  <BhutanExperiences />
  <BhutanGallery />
  <BhutanJourneysTeaser />
  <FinalCta />
</Base>
