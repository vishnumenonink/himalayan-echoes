---
import Base from "../layouts/Base.astro";
---

<Base
  title="Journeys — Himalayan Echoes"
  description="Hand-crafted journeys across Bhutan, Nepal, Tibet and the wider Himalaya."
  transparentHeader={true}
>
  <section class="min-h-[70vh] flex items-end bg-slate-mountain text-cream pb-24">
    <div class="container-edge mx-auto">
      <p class="text-eyebrow text-cream/60 mb-6 reveal-fast">Journeys</p>
      <h1 class="text-mega leading-[0.95] reveal">
        Every<br />path<br />a story.
      </h1>
    </div>
  </section>

  <section class="section-y container-edge mx-auto">
    <p class="text-eyebrow text-ink-mute mb-6 reveal-fast">Coming next</p>
    <h2 class="text-h1 max-w-3xl reveal">
      Immersive listing — full-bleed imagery, horizontal storytelling, filter chips.
    </h2>
  </section>
</Base>
